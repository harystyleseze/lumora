    "pino": "^9.6.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
