    "http-proxy-middleware": "^3.0.5",
    "pino": "^9.6.0",
    "uuid": "^11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.3",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "tsup": "8.5.1",
